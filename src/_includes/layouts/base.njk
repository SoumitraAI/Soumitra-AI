<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {{ site.name }}{% else %}{{ site.name }} — {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="view-transition" content="same-origin">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="wrap header-inner">
      <a class="wordmark" href="/">Soumitra<span class="wordmark-dot">.AI</span></a>
      <nav class="site-nav" aria-label="Main">
        <a href="/research/">Research</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
        <a class="nav-cta" href="/work-with-me/">Work with me</a>
      </nav>
    </div>
  </header>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="footer-inner">
        <div>
          <p class="footer-wordmark">Soumitra<span class="wordmark-dot">.AI</span></p>
          <p class="footer-tag">{{ site.tagline }}</p>
        </div>
        <nav class="footer-nav" aria-label="Footer">
          <a href="/research/">Research</a>
          <a href="/blog/">Blog</a>
          <a href="/tags/">Sectors</a>
          <a href="/about/">About</a>
          <a href="/work-with-me/">Work with me</a>
          {% if site.linkedin %}<a href="{{ site.linkedin }}" rel="me noopener" target="_blank">LinkedIn ↗</a>{% endif %}
        </nav>
        <p class="footer-meta">© {% year %} {{ site.author }}.<br>All analysis is the author's own.</p>
      </div>
      <p class="footer-giant" aria-hidden="true">Soumitra.AI</p>
    </div>
  </footer>

  <script>
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          el.classList.add('in');
        });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('[data-reveal]').forEach(function (el) {
        io.observe(el);
      });
    })();
  </script>

  {% if diagrams %}
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    mermaid.initialize({
      startOnLoad: true,
      securityLevel: 'strict',
      fontFamily: "'IBM Plex Sans', sans-serif",
      theme: 'base',
      themeVariables: {
        background: '#0d1825',
        primaryColor: '#112134',
        primaryBorderColor: '#2fd6c3',
        primaryTextColor: '#e9eff5',
        lineColor: '#6e8296',
        secondaryColor: '#13263c',
        tertiaryColor: '#0d1825',
        fontSize: '15px'
      }
    });
  </script>
  {% endif %}
</body>
</html>
