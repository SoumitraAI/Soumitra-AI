---
layout: layouts/base.njk
---
<article class="article wrap-narrow">
  <header class="article-header">
    {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
    <h1>{{ title }}</h1>
    {% if description %}<p class="dek">{{ description }}</p>{% endif %}
  </header>
  <div class="prose">
    {{ content | safe }}
  </div>
</article>
